# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Phase 12 / M-01: phase12_deploy.py writes TRADE_MIX_HAS_MAKER_TAKER here for CI
# parity tests to source. Listed explicitly so grep -E "^\.env\.test$" matches the
# Phase 12 Plan 12-10 acceptance contract (the .env* glob above already covers it).
.env.test

# vercel
.vercel

# gstack security reports and local state
.gstack/

# Claude Code local session state (settings.local.json, worktrees, locks) and
# gstack planning artifacts — both are per-developer tooling, never in the repo.
.claude/
.planning/

# Per-developer AI scratchpads (ADVERSARIAL_USER_NOTES.md etc.) — never committed.
tasks/

# supabase CLI local state
supabase/.temp/

# Filled-in pitch / demo templates contain sensitive partner + allocator info.
# Templates are committed as *.template.md; the bare .md is the filled-in copy
# the founder edits locally and never commits to a public repo.
docs/pitch/partner-qualification-notes.md
docs/demos/before-metric.md
docs/demos/before-after.md

# python
__pycache__/
*.pyc
.coverage
*.venv/

# playwright
.playwright-mcp/
/test-results/
/playwright-report/

# screenshots and docs at repo root
*.png
*.docx
# ...but commit Playwright snapshot baselines — they ARE the contract the
# screenshot regression suite asserts against. C-0300 sentinel
# (e2e/demo-screenshot.spec.ts:24) fails CI if any of these PNGs are
# missing; without the allow rule below they were silently ignored.
!e2e/**/*.png

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI local state (linked project metadata)
analytics-service/supabase/
.env*.local
fix-list.md
