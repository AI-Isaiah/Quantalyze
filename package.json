{
  "name": "quantalyze",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location node_modules/.cache/.eslintcache src/ && tsx scripts/check-admin-route-manifest.ts && tsx scripts/check-route-contract.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify:phase18": "tsx scripts/verify-phase18-artifacts.ts",
    "check:founder-lp-readiness": "tsx scripts/check-founder-lp-readiness.ts",
    "check:admin-route-manifest": "tsx scripts/check-admin-route-manifest.ts",
    "check:route-contract": "tsx scripts/check-route-contract.ts",
    "worker:dev": "cd analytics-service && .venv/bin/python main_worker.py",
    "schema:functions": "tsx scripts/dump-sql-functions.ts",
    "schema:functions:check": "tsx scripts/dump-sql-functions.ts --check"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "1.1.15",
    "@sentry/nextjs": "^10.62.0",
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "lightweight-charts": "^5.2.0",
    "next": "^16.2.3",
    "posthog-js": "^1.395.0",
    "posthog-node": "^5.38.6",
    "puppeteer-core": "^25.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "recharts": "^3.9.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "resend": "^6.16.0",
    "server-only": "^0.0.1",
    "svix": "^1.96.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.2",
    "ws": "^8.21.0"
  },
  "version": "0.35.0.26"
}
