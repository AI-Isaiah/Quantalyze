# Quantalyze environment manifest.
#
# This file is the ENFORCED manifest, not just an example: every literal
# `process.env.<KEY>` read in src/ must be documented here (or allowlisted as a
# platform/test/indirect key), and every active key here must be read in src/.
# The guard is `src/__tests__/contracts/env-manifest.test.ts` — add a key here
# in the same PR that introduces its read, or CI goes red.
#
# Config lives across 4 planes; each key notes its owning plane:
#   [Vercel]   Vercel project env (frontend + API routes)
#   [Railway]  analytics-service env (Python worker) — see the reference block
#   [Supabase] Postgres GUCs / feature_flags rows (e.g. pg_cron)
#   [GitHub]   Actions secrets/vars (CI only — not in this file)
#
# ─── Required ────────────────────────────────────────────────────────
# Supabase project credentials [Vercel]
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin email — gates /admin routes in the proxy + profiles.is_admin fallback
ADMIN_EMAIL=founder@example.com

# App URL — used by PDF routes, email links, and CSRF allowlist
NEXT_PUBLIC_APP_URL=https://quantalyze.com
NEXT_PUBLIC_SITE_URL=https://quantalyze.com

# Extra CSRF same-origin allowlist (comma-separated), appended to the derived
# app/site origins in src/lib/csrf.ts. Optional — unset = only the app origins
# are trusted. [Vercel]
# NEXT_PUBLIC_ALLOWED_ORIGINS=https://staging.quantalyze.com

# ─── Analytics Service (required for trade sync, optimizer, verification) ─
# Default port is 8002. Local dev: `cd analytics-service && uvicorn ...`
ANALYTICS_SERVICE_URL=http://localhost:8002
ANALYTICS_SERVICE_KEY=your-service-key

# Shared secret for the Next layer → analytics-service /internal routes
# (e.g. /api/keys/[id]/permissions). Missing on the Next layer = 502
# with the literal string "INTERNAL_API_TOKEN is not configured on the
# Next layer." Must match analytics-service's INTERNAL_API_TOKEN env.
INTERNAL_API_TOKEN=your-internal-token

# ─── Cron / Scheduled Tasks ─────────────────────────────────────────
# Shared secret for Vercel Cron endpoints (alert-digest, warm-analytics).
# Missing = cron returns 401.
CRON_SECRET=your-cron-secret

# HMAC secret (>= 16 chars) for one-click alert-acknowledgement email tokens
# (src/lib/alert-ack-token.ts). Read indirectly via process.env[SECRET_ENV], so
# the env-manifest grep can't see it — it lives in the test's INDIRECT_READS
# allowlist. Soft-skip: the signer throws if unset, but the only caller
# (src/app/api/alert-digest) catches it and ships the digest with a plain
# dashboard link instead of an ack button; the verifier returns false (no
# throw). Set it to enable one-click ack links. [Vercel]
ALERT_ACK_SECRET=your-alert-ack-secret-at-least-16-chars

# ─── PDF Generation ─────────────────────────────────────────────────
# HMAC secret for demo PDF token signing (>= 16 chars)
DEMO_PDF_SECRET=your-demo-pdf-secret-at-least-16-chars

# Optional: override Chromium path for local dev (auto-detected on Vercel)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── Email (optional — missing = emails silently skipped) ─────── [Vercel]
RESEND_API_KEY=your-resend-api-key

# Verifies inbound Resend webhook signatures (src/app/api/webhooks/resend).
# Unset = the webhook rejects all calls. Optional unless using delivery events.
# RESEND_WEBHOOK_SECRET=whsec_...

# From: header for operational alert emails (flag-monitor breach/WARN/ALERT).
# Optional — defaults to "Quantalyze <alerts@quantalyze.com>".
# RESEND_ALERT_FROM=Quantalyze <alerts@quantalyze.com>

# Platform branding in emails and legal pages
PLATFORM_NAME=Quantalyze
PLATFORM_EMAIL=notifications@quantalyze.com

# ─── Founder LP report cron (Phase 18 / LP-01) ─────────────────────
# UUID of the strategy whose factsheet PDF the monthly cron emails to founder.
# Set in Vercel UI → Settings → Environment Variables → Production. Founder
# MUST flip strategies.status to 'published' before the first scheduled tick
# (`15 9 1 * *`); see .planning/phase-18/founder-lp-runbook.md +
# `npm run check:founder-lp-readiness`.
FOUNDER_LP_STRATEGY_ID=

# Recipient email for the founder LP report (success + failure alerts).
# Falls back to ADMIN_EMAIL if unset, but explicit value preferred.
# Phase 19 / BACKBONE-05 — also the recipient for /api/cron/flag-monitor
# WARN, ALERT, H-2 (zero-denominator), and D-3 (PGRST) breach emails.
FOUNDER_LP_REPORT_TO=

# ─── Phase 19 — Unified backbone auto-rollback (BACKBONE-05 / BACKBONE-09) ─
# Default OFF until the founder enables (Assumption A8). Setting "on" routes
# /process-key traffic through the unified router; the kill-switch row in
# Supabase feature_flags overrides this at runtime within the cache TTL.
PROCESS_KEY_UNIFIED_BACKBONE=off

# Feature flag: route compute through the durable compute-jobs queue instead of
# inline computation. Read by the wizard finalize, CSV finalize, and key-sync
# routes (src/app/api/strategies/{finalize-wizard,csv-finalize}, keys/sync).
# Unset / != "true" = inline path. [Vercel]
# USE_COMPUTE_JOBS_QUEUE=true

# Sentry org slug — used by /api/cron/flag-monitor (error-rate alerter)
# to query the events API at ${SENTRY_API_BASE}/${SENTRY_ORG_SLUG}/events/.
# Verify the response shape with `bash scripts/probe-sentry-events-api.sh`
# BEFORE deploying the cron (Assumption A1).
SENTRY_ORG_SLUG=

# Sentry API base URL — REQUIRED for EU-region orgs. Default is the global
# `https://sentry.io` which only returns data for US-region organizations.
# EU-region orgs MUST override here or the cron silently returns empty data
# (HTTP 200 + `{"data": []}`), giving the auto-rollback + soak-gate code paths
# false-clean numerators. Find the region via the auth-token JWT (`region_url`
# claim) or the Sentry web UI org URL.
#   US: https://sentry.io/api/0/organizations          (default — omit to use)
#   EU: https://de.sentry.io/api/0/organizations
SENTRY_API_BASE=

# Cache TTL (seconds) for the in-process unified-backbone flag read seam in
# both src/lib/feature-flags.ts and analytics-service/services/feature_flags.py.
# Default is 30s. During the 7-day stability window the founder can set this
# to "5" to reduce kill-switch propagation latency from 30s → 5s; combined
# with the 15-min cron tick the worst-case auto-rollback latency is
# ≤15min05s. After PR-D ships this can be unset (defaults back to 30s).
PHASE_19_STABILITY_CACHE_TTL_S=

# ─── Scheduling (optional — enables "Book Intro Call" button) ────────
NEXT_PUBLIC_SCHEDULING_URL=https://calendly.com/your-team/intro-call

# ─── Observability (optional) ───────────────────────────────────────
# Plausible analytics domain (wired in layout.tsx)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=quantalyze.com

# PostHog — powers the /for-quants funnel events (Sprint 1 Task 1.1).
# Missing = server + client events silently no-op, /for-quants still renders.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server-side PostHog query API — powers the admin usage-metrics panel
# (src/lib/admin/usage-metrics.ts). Distinct from the NEXT_PUBLIC_* client
# keys above. Missing = the admin panel renders without usage metrics. [Vercel]
# POSTHOG_API_KEY=phx_...
# POSTHOG_PROJECT_ID=
# POSTHOG_HOST=https://us.posthog.com

# Sentry — optional but recommended for production error tracking.
# DSN wired in instrumentation.ts; auth token used for source-map uploads.
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─── Rate Limiting ──────────────────────────────────────────── [Vercel]
# In PRODUCTION (VERCEL_ENV=production) these are REQUIRED: if unset, rate-
# limited routes fail-CLOSED with 503 (a misconfigured prod must not silently
# disable limits). In dev/preview/CI, unset = fail-OPEN (all requests allowed)
# so local dev works without Upstash. See src/lib/ratelimit.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Platform Branding (optional, public) ────────────────────────────
NEXT_PUBLIC_PLATFORM_NAME=Quantalyze

# ─── Analytics Service Environment (set in Railway / analytics-service/.env)
# These are NOT used by the Next.js app — listed here for reference only. [Railway]
# TRIPWIRE: the Python worker reads SUPABASE_SERVICE_KEY (short name); the TS
# app above reads SUPABASE_SERVICE_ROLE_KEY (long name). Same secret value,
# different env-var name per plane — both must be set for full prod sync.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# SERVICE_KEY=your-service-key
# KEK=your-key-encryption-key
# KEK_VERSION=1
# ALLOWED_ORIGINS=http://localhost:3000
# RESEND_API_KEY=your-resend-api-key
